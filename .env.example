# Application
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/vtu-platform

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# HubNet
HUBNET_API_URL=https://api.hubnet.app
HUBNET_API_KEY=your_hubnet_api_key

# VTPass
VTPASS_API_URL=https://vtpass.com/api
VTPASS_USERNAME=your_vtpass_username
VTPASS_PASSWORD=your_vtpass_password
VTPASS_API_KEY=your_vtpass_api_key

# Reloadly
RELOADLY_CLIENT_ID=your_reloadly_client_id
RELOADLY_CLIENT_SECRET=your_reloadly_client_secret
RELOADLY_BASE_URL=https://topups.reloadly.com

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@yourplatform.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Admin Registration Secret (first admin setup)
ADMIN_SETUP_SECRET=your_admin_setup_secret
